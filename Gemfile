source 'https://rubygems.org'
group :jekyll_plugins do
    # Pin Jekyll to the 4.3 line and the sassc-based Sass converter.
    # Jekyll 4.4 switched to jekyll-sass-converter 3.x -> sass-embedded, whose
    # native extension fails to build on the CI runner
    # (NameError: uninitialized constant JSON::Fragment), breaking deploys.
    gem 'jekyll', '~> 4.3.0'
    gem 'jekyll-sass-converter', '~> 2.0'
    gem 'jekyll-email-protect'
    gem 'jekyll-feed'
    gem 'jekyll-github-metadata'
    gem 'jekyll-paginate-v2'
    gem 'jekyll-scholar'
    gem 'jekyll-twitter-plugin'
    gem 'jekyll-sitemap'
    gem 'jemoji'
    gem 'unicode_utils'
    gem 'webrick'
end
